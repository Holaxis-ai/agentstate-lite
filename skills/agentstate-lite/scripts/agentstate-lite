#!/usr/bin/env bash
# Shim for the self-contained agentstate-lite CLI bundle. Resolves its own directory (so it works
# regardless of CWD or how it's invoked) and runs the committed .mjs under node.
#
# Node >= 20 floor guard: the bundle targets node20 and package.json engines requires >= 20. A bare
# `exec node` would give a node-18 (or no-node) user a cryptic syntax/API crash, so probe the
# version once.
ver="$(node -v 2>/dev/null)"
major="${ver#v}"
major="${major%%.*}"
case "$major" in
  ''|*[!0-9]*)
    echo "agentstate-lite requires Node >= 20 (found ${ver:-none})" >&2
    exit 1
    ;;
esac
if [ "$major" -lt 20 ]; then
  echo "agentstate-lite requires Node >= 20 (found ${ver:-none})" >&2
  exit 1
fi
exec node "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/agentstate-lite.mjs" "$@"
