{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/api/schema/stryker-core.json",
  "packageManager": "npm",
  "testRunner": "tap",
  "tap": {
    "testFiles": ["test/*.test.ts"],
    "nodeArgs": ["--import", "./test/ts-loader.mjs", "--test-reporter=tap", "-r", "../../scripts/stryker-cwd-pin.cjs", "-r", "{{hookFile}}", "{{testFile}}"],
    "forceBail": true
  },
  "buildCommand": "node build.mjs",
  "mutate": [
    "src/errors.ts",
    "src/mutate.ts",
    "src/board-attribution.ts",
    "src/bundle.ts",
    "src/actor.ts",
    "src/sync-outcomes.ts",
    "src/commands/sync.ts",
    "src/commands/sync-establish.ts"
  ],
  "inPlace": true,
  "disableTypeChecks": true,
  "coverageAnalysis": "perTest",
  "reporters": ["html", "json", "clear-text", "progress"],
  "ignoreStatic": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "htmlReporter": { "fileName": "reports/mutation/mutation.html" },
  "jsonReporter": { "fileName": "reports/mutation/mutation.json" },
  "tempDirName": ".stryker-tmp"
}
