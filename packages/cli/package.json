{
  "name": "agentstate-lite",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent-facing CLI (AXI) for reading and writing local OKF knowledge bundles: context notes, docs, cross-links, and live bundle Views.",
  "keywords": [
    "okf",
    "knowledge",
    "agent",
    "axi",
    "cli",
    "markdown",
    "context-notes"
  ],
  "license": "MIT",
  "homepage": "https://github.com/Holaxis-ai/agentstate-lite#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Holaxis-ai/agentstate-lite.git"
  },
  "bugs": {
    "url": "https://github.com/Holaxis-ai/agentstate-lite/issues"
  },
  "bin": {
    "agentstate-lite": "dist/agentstate-lite.mjs",
    "aslite": "dist/agentstate-lite.mjs"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node build.mjs && AGENTSTATE_LITE_NO_AUTOPULL=1 GIT_AUTHOR_NAME=test-suite GIT_AUTHOR_EMAIL=test-suite@example.invalid GIT_COMMITTER_NAME=test-suite GIT_COMMITTER_EMAIL=test-suite@example.invalid node --test --import ./test/ts-loader.mjs ./test/*.test.ts",
    "gen:skill": "node scripts/gen-skill.mjs",
    "check:skill": "node scripts/gen-skill.mjs --check",
    "gen:skill:bundle": "node scripts/gen-skill.mjs --target skill",
    "check:skill:bundle": "node scripts/gen-skill.mjs --target skill --check",
    "build:plugin-bundle": "node scripts/build-plugin-bundle.mjs && node scripts/gen-skill.mjs --target skill",
    "check:bundle": "node scripts/check-skill-bundle.mjs",
    "prepublishOnly": "node ../../scripts/verify-npm-package.mjs"
  },
  "devDependencies": {
    "@agentstate-lite/board-git": "*",
    "@agentstate-lite/core": "*",
    "@agentstate-lite/server": "*",
    "@toon-format/toon": "2.3.0",
    "@types/node": "^22.0.0",
    "axi-sdk-js": "0.1.8",
    "esbuild": "0.25.12",
    "pako": "2.1.0",
    "typescript": "^5.4.0"
  }
}
