{
  // Real deployable config (Stage-1 Unit 2b Part B) â€” same file the test harness
  // (`test/env.ts`'s `getPlatformProxy({ configPath: WRANGLER_CONFIG })`) resolves D1/R2
  // bindings from, so it must stay valid for BOTH purposes: local `node --test` simulation
  // (no real Cloudflare account touched) AND a real `wrangler deploy`. `database_id` /
  // `bucket_name` below are still PLACEHOLDERS â€” a human operator fills in the real
  // production values (or runs `wrangler d1 create` / `wrangler r2 bucket create` first) as
  // part of the human-gated Part D deploy; `getPlatformProxy` never talks to a real Cloudflare
  // account regardless of what these placeholders say.
  //
  // `main` points at the Worker fetch entry (`src/worker.ts`, Part B). `getPlatformProxy`
  // does NOT execute `main` â€” it only reads this file for binding declarations â€” so adding it
  // does not affect the test harness; it is required for `wrangler dev`/`wrangler deploy`.
  "name": "agentstate-lite",
  "main": "src/worker.ts",
  "compatibility_date": "2026-01-01",
  // REQUIRED, and the reason is recorded here rather than left to guesswork: core's
  // `backendFor(bundle)` (`packages/core/src/bundle.ts`) statically references `new
  // FilesystemBackend(bundle.root)` as its default-adapter fallback for a `Bundle` with no
  // explicit `.backend` â€” this is what lets `writeDocVersioned` (which `router.ts`'s
  // `handleWriteDoc` MUST call, per the one-engine rule, so a Worker-received write gets the
  // SAME OKF Â§9.2/id-safety/reserved-file validation every other write path gets) work for
  // every caller, including ones with no backend of their own. Because that reference is
  // reachable from the SAME function `createRouterForBackend`'s write path calls, a bundler
  // cannot tree-shake it away â€” `node:fs`/`node:path`/`node:crypto` (from `FilesystemBackend`)
  // and `node:http` (from `@agentstate-lite/server`'s `serve.ts`, pulled in via the package's
  // barrel export) end up in the Worker's dependency graph even though this Worker ALWAYS
  // constructs an explicit `D1R2Backend` and that fallback branch is NEVER taken at runtime.
  // `nodejs_compat` lets `wrangler`/workerd resolve those imports instead of failing the
  // build; the code paths they back are simply dead weight here, never executed. The real
  // fix â€” a worker-clean core entry-point split so `backendFor`'s fallback isn't statically
  // reachable from a caller that always supplies its own backend â€” is a DEFERRED, separate
  // unit (Stage-1 Unit 2b Part B review finding), not attempted in this pass.
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "agentstate-lite",
      // PLACEHOLDER â€” run `wrangler d1 create agentstate-lite` and put YOUR database id
      // here (or keep real values in an untracked wrangler.local.jsonc and deploy with
      // `wrangler deploy -c wrangler.local.jsonc`; migrations likewise take `-c`).
      "database_id": "00000000-0000-0000-0000-000000000000",
      // Where `wrangler d1 migrations apply` looks for SQL migrations (this package's
      // default matches wrangler's own default, stated explicitly per Part B's ask).
      "migrations_dir": "migrations",
    },
  ],
  "r2_buckets": [
    { "binding": "BUCKET", "bucket_name": "agentstate-lite" },
  ],
  // Static assets (same-origin SPA serving â€” auth-agnostic infrastructure, reused by
  // whatever browser-login lands): the SPA shell lives at the assets ROOT with
  // single-page-application fallback, and `run_worker_first` pins EVERY `/v0/*` request to
  // the gated fetch handler regardless of fetch mode (SPA fallback cannot be sub-path
  // scoped, and a NAVIGATION request to /v0 would otherwise serve the shell instead of the
  // API). `packages/ui/public` is the committed placeholder shell; the real Vite SPA
  // repoints this at `../ui/dist`. `getPlatformProxy` (the test harness) ignores assets
  // entirely; assets routing is exercised by the SPA's `wrangler dev`-based E2E and by the
  // human-gated deploy acceptance.
  "assets": {
    "directory": "../ui/public",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/v0/*"],
  },
  // API_KEY and KEY_PEPPER are BOTH SECRETS (`wrangler secret put API_KEY`,
  // `wrangler secret put KEY_PEPPER`), never a `vars` entry â€” neither may ever be checked
  // into this file. `createAuthGate` (`src/auth.ts`, Stage-2 auth Part A) fails closed when
  // EITHER is unset: API_KEY is the root bootstrap identity's shared secret; KEY_PEPPER is
  // the HMAC pepper every minted invite token / API key is hashed under at rest
  // (`src/tokens.ts`, `migrations/0002_auth.sql`).
}
