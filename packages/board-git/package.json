{
  "name": "@agentstate-lite/board-git",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The board's git channel — porcelain ops, ref-to-ref doc diffs, the sync state store, engine helpers, and the autopull mechanic. Command UX (args, rendering, envelopes, exit codes) lives in the CLI.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import ./test/ts-loader.mjs ./test/*.test.ts"
  },
  "dependencies": {
    "@agentstate-lite/core": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.4.0"
  }
}
